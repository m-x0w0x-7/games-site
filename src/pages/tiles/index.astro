---
import Layout from "../../layouts/Layout.astro"
---

<Layout
  title="Tiles"
  description="いわゆる2048。同じ数字のタイルを組み合わせて2048を目指そう！"
  bodyClass="page-tiles"
>
  <link slot="head"
        href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,500;1,6..96,500&display=swap"
        rel="stylesheet"
  />
  <script slot="head" src="/assets/scripts/tiles.js"></script>

  <div class="inner">
    <div class="top">
      <h1 class="title">Tiles</h1>
      <div class="scores">
        <div class="score">
          <div class="score-label">Score</div>
          <div class="score-val" id="score">0</div>
        </div>
        <div class="score">
          <div class="score-label">Best</div>
          <div class="score-val" id="best">0</div>
        </div>
      </div>
    </div>
    <div class="btns">
      <button onclick="newGame()">New Game</button>
      <button onclick="undo()">Undo</button>
    </div>
    <div class="game">
      <div class="grid" id="grid"></div>
      <div class="tiles" id="tiles"></div>
      <div class="overlay" id="overlay">
        <h2 id="ov-title">Game Over</h2>
        <p id="ov-sub">Score: 0</p>
        <button id="ov-btn" onclick="newGame()">Try Again</button>
      </div>
    </div>
    <p class="hint">Swipe to move · Tap Undo to go back one step</p>
  </div>
  <canvas id="bg"></canvas>
</Layout>

<style is:global>
.inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.top {
  width: 100%;
  max-width: 400px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 14px;
}
.title {
  font-size: 56px;
  color: var(--moon);
  line-height: 1;
  text-shadow: 0 0 10px rgb(75 137 163 / 0.4);
  letter-spacing: 0.02em;
}
.scores {
  display: flex;
  gap: 8px;
}
.score {
  background: var(--surface);
  border-radius: 12px;
  padding: 8px 16px;
  text-align: center;
  min-width: 76px;
}
.score-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
}
.score-val {
  font-size: 22px;
  font-weight: 600;
  margin-top: 2px;
  transition: transform 0.12s;
}
.score-val.bump {
  transform: scale(1.25);
}
.btns {
  width: 100%;
  max-width: 400px;
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
}
button {
  background: var(--surface);
  color: var(--text);
  border: none;
  border-radius: 12px;
  padding: 13px 20px;
  font-family: 'Bodoni Moda', serif;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  flex: 1;
  transition:
    background 0.15s,
    transform 0.1s;
}
button:active {
  transform: scale(0.97);
  background: #26263a;
}
.game {
  position: relative;
  width: 100%;
  max-width: 400px;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.grid {
  background: var(--grid);
  border-radius: 16px;
  padding: 10px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  opacity: 0.8;
  touch-action: none;
  user-select: none;
  -webkit-user-select: none;

  .cell {
    background: var(--empty);
    border-radius: 10px;
    aspect-ratio: 1;
  }
}
.tiles {
  position: absolute;
  inset: 10px;
  pointer-events: none;

  .tile {
    position: absolute;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    line-height: 1;
    transition:
      left 0.18s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      top 0.18s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }
  .tile.new {
    animation: water-pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }
  .tile.merged {
    z-index: 10;
    animation: lunar-burst 0.4s ease-out forwards;
  }
}

@keyframes water-pop {
  0% {
    transform: scale(0.5) translateY(10px);
    opacity: 0;
    filter: blur(10px);
  }
  100% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
}
@keyframes lunar-burst {
  0% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(164, 226, 241, 0);
  }
  30% {
    box-shadow: 0 0 10px 5px rgba(164, 226, 241, 0.4);
  }
  60% {
    transform: scale(1.08);
  }
  90% {
    transform: scale(1);
  }
  100% {
    box-shadow: 0 0 20px 10px rgba(164, 226, 241, 0);
  }
}

.overlay {
  position: absolute;
  inset: 0;
  border-radius: 16px;
  background: rgba(10, 10, 20, 0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
  backdrop-filter: blur(2px);
  z-index: 10;
}
.overlay.on {
  opacity: 1;
  pointer-events: auto;
}
.overlay h2 {
  font-size: 36px;
  font-weight: 500;
  color: var(--gold);
}
.overlay p {
  font-size: 14px;
  font-weight: 500;
  color: var(--muted);
}
.overlay button {
  background: var(--gold);
  color: #0f0f14;
  font-weight: 600;
  font-size: 15px;
  font-weight: 500;
  padding: 14px 36px;
  border-radius: 12px;
  flex: 0;
}
.overlay button:active {
  background: #d09610;
}
.hint {
  text-align: center;
  font-size: 12px;
  color: var(--muted);
  margin-top: 24px;
}

#bg {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
}
</style>