---
import GameLayout from "../../layouts/GameLayout.astro"
---

<GameLayout
  title="Slides"
  description="絵あわせスライドパズル。バラバラになった絵を元通りに並べよう！"
  bodyClass="page-slides"
>
  <link slot="head"
        href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,500;1,6..96,500&display=swap"
        rel="stylesheet"
  />

  <div class="slides-app" id="slides-app" data-phase="selecting">

    <!-- 画像ピッカー（selectingフェーズ） -->
    <section class="picker-section">
      <p class="picker-title">画像を選んでください</p>
      <div class="picker-list">
        <button class="picker-btn" data-index="0" aria-pressed="false">
          <img src="/assets/images/slides/img_01.jpg" alt="画像1" />
        </button>
        <button class="picker-btn" data-index="1" aria-pressed="false">
          <img src="/assets/images/slides/img_02.jpg" alt="画像2" />
        </button>
        <button class="picker-btn" data-index="2" aria-pressed="false">
          <img src="/assets/images/slides/img_03.jpg" alt="画像3" />
        </button>
      </div>
      <button class="custom-image-btn" id="custom-image-btn">自分の画像を使う</button>
      <input type="file" accept="image/*" id="image-file-input" style="display:none" />
      <div class="picker-note">
        <p class="picker-note__heading">【画像について】</p>
        <p class="picker-note__text">
          画像は端末内でのみ処理され、外部へ送信されることはありません。<br>
          ※ 著作権・肖像権にご注意ください。SNS投稿等のトラブルについて当サイトは責任を負いかねます。
        </p>
        <p class="picker-note__link">
          詳細は<a href="/policy">プライバシーポリシー</a>でご確認ください
        </p>
      </div>
    </section>

    <!-- ゲーム本体（ready / playing / clearフェーズ） -->
    <div class="puzzle-container">
      <div class="puzzle-board" id="puzzle-board"></div>
    </div>
    <div class="controls">
      <div class="info">
        <div class="info-item">
          <span class="info-label">手数</span>
          <span class="info-value" id="move-count">0</span>
        </div>
      </div>
      <p class="message" id="message"></p>
      <div class="button-group">
        <button class="action-btn" id="start-btn">Start</button>
        <button class="action-btn" id="retry-btn">同じ画像でもう一度</button>
        <button class="action-btn action-btn--secondary" id="reselect-btn">画像を選び直す</button>
      </div>
    </div>

  </div>
</GameLayout>

<script>
import { init } from '../../scripts/slides/main.js';
init();
</script>

<style is:global>
.page-slides {
  background: linear-gradient(180deg, var(--bgLight) 0%, var(--bg) 100%);
  background-attachment: fixed;
  color: var(--text);
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Bodoni Moda', serif;
  font-optical-sizing: auto;
  font-weight: 500;
  font-style: normal;
  font-variation-settings: 'wdth' 100;
}

.slides-app {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 16px;
  gap: 20px;
}

/* ===== フェーズ制御 ===== */

/* ピッカーはデフォルト非表示 */
.picker-section {
  display: none;
}

/* selectingフェーズ: ピッカー表示、ゲームUI非表示 */
.slides-app[data-phase="selecting"] .picker-section {
  display: flex;
}
.slides-app[data-phase="selecting"] .puzzle-container {
  display: none;
}
.slides-app[data-phase="selecting"] .controls {
  display: none;
}

/* ボタン: デフォルト非表示 */
#start-btn,
#retry-btn,
#reselect-btn {
  display: none;
}

/* readyフェーズ: スタートボタンのみ表示 */
.slides-app[data-phase="ready"] #start-btn {
  display: block;
}

/* clearフェーズ: 2ボタン表示 */
.slides-app[data-phase="clear"] #retry-btn {
  display: block;
}
.slides-app[data-phase="clear"] #reselect-btn {
  display: block;
}

/* ===== ピッカー ===== */

.picker-section {
  flex-direction: column;
  align-items: center;
  gap: 20px;
  width: 100%;
  max-width: 400px;
}

.picker-title {
  font-size: 13px;
  color: var(--muted);
  letter-spacing: 0.05em;
  text-align: center;
}

.picker-list {
  display: flex;
  flex-direction: row;
  gap: 12px;
  justify-content: center;
}

.picker-btn {
  width: 100px;
  height: 100px;
  padding: 0;
  border: 2.5px solid transparent;
  border-radius: 10px;
  overflow: hidden;
  cursor: pointer;
  background: var(--surface);
  transition:
    border-color 0.15s,
    transform 0.1s,
    box-shadow 0.15s;
  flex-shrink: 0;
}

.picker-btn img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
}

.picker-btn:active {
  transform: scale(0.96);
}

.picker-btn--selected {
  border-color: var(--gold);
  box-shadow: 0 0 0 1px var(--gold);
}

.picker-note {
  font-size: 11px;
  color: var(--deepBlue);
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 16px;
  border-radius: 8px;
  background: rgb(var(--muted-rgb) / 0.7);
}

.picker-note__heading {
  font-weight: 600;
  letter-spacing: 0.04em;
}

.picker-note__text {
  line-height: 1.7;
  text-align: left;
}

.picker-note__link a {
  text-decoration: underline;
  text-underline-offset: 0.2em;
  transition: opacity 0.2s;
}

.picker-note__link a:hover {
  opacity: 0.7;
}

/* ===== 盤面 ===== */

.puzzle-container {
  width: 100%;
  max-width: 400px;
}

.puzzle-board {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  border-radius: 12px;
  background: var(--grid);
  cursor: pointer;
  touch-action: none;
  user-select: none;
  -webkit-user-select: none;
}

/* タイル */
.slide-tile {
  position: absolute;
  top: 0;
  left: 0;
  background-repeat: no-repeat;
  transition: transform 0.18s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
  cursor: pointer;
  box-shadow: 0 0 0 1.5px rgba(0, 0, 0, 0.25) inset;
}

.slide-tile:active {
  filter: brightness(1.1);
}

/* ===== コントロール ===== */

.controls {
  width: 100%;
  max-width: 400px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.info {
  display: flex;
  gap: 12px;
}

.info-item {
  background: var(--surface);
  border-radius: 12px;
  padding: 8px 24px;
  text-align: center;
  min-width: 100px;
}

.info-label {
  display: block;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
}

.info-value {
  display: block;
  font-size: 22px;
  font-weight: 600;
  margin-top: 2px;
}

.message {
  font-size: 13px;
  color: var(--muted);
  min-height: 20px;
  text-align: center;
  transition: color 0.3s;
}

.message[data-phase="clear"] {
  color: var(--gold);
  font-size: 18px;
}

/* ===== ボタン ===== */

.button-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  width: 100%;
  max-width: 280px;
}

.action-btn {
  background: var(--surface);
  color: var(--text);
  border: none;
  border-radius: 12px;
  padding: 13px 0;
  width: 100%;
  font-family: 'Bodoni Moda', serif;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition:
    background 0.15s,
    transform 0.1s;
}

.action-btn:active {
  transform: scale(0.97);
  background: #26263a;
}

.action-btn--secondary {
  background: transparent;
  color: var(--muted);
  font-size: 13px;
}

.action-btn--secondary:active {
  background: var(--surface);
  color: var(--text);
}

/* ===== 自分の画像ボタン ===== */

.custom-image-btn {
  background: transparent;
  color: var(--muted);
  border: 1.5px solid rgba(255, 255, 255, 0.12);
  border-radius: 10px;
  padding: 10px 20px;
  font-family: 'Bodoni Moda', serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition:
    color 0.15s,
    border-color 0.15s,
    transform 0.1s;
  margin-top: 4px;
}

.custom-image-btn:active {
  color: var(--text);
  border-color: rgba(255, 255, 255, 0.3);
  transform: scale(0.97);
}

/* ===== クロッパーモーダル ===== */

.cropper-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 16px;
}

.cropper-modal {
  width: 100%;
  max-width: 480px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cropper-hint {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  letter-spacing: 0.03em;
}

.cropper-viewport {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  background: #0a0a0a;
  overflow: hidden;
  border-radius: 8px;
  touch-action: none;
}

.cropper-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  pointer-events: none;
  user-select: none;
  -webkit-user-select: none;
}

.cropper-shade {
  position: absolute;
  background: rgba(0, 0, 0, 0.58);
  pointer-events: none;
}

.cropper-frame {
  position: absolute;
  border: 2px solid rgba(255, 255, 255, 0.85);
  cursor: move;
  touch-action: none;
  box-sizing: border-box;
}

.cropper-handle {
  position: absolute;
  width: 20px;
  height: 20px;
  background: #fff;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.cropper-handle[data-corner="tl"] { top: 0;    left: 0;    cursor: nwse-resize; }
.cropper-handle[data-corner="tr"] { top: 0;    left: 100%; cursor: nesw-resize; }
.cropper-handle[data-corner="bl"] { top: 100%; left: 0;    cursor: nesw-resize; }
.cropper-handle[data-corner="br"] { top: 100%; left: 100%; cursor: nwse-resize; }

.cropper-actions {
  display: flex;
  gap: 10px;
}

.cropper-btn {
  flex: 1;
  padding: 13px 0;
  border: none;
  border-radius: 12px;
  font-family: 'Bodoni Moda', serif;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition:
    background 0.15s,
    transform 0.1s;
}

.cropper-btn:active {
  transform: scale(0.97);
}

.cropper-btn--confirm {
  background: var(--gold, #d4af37);
  color: #000;
}

.cropper-btn--confirm:active {
  background: #b8972f;
}

.cropper-btn--cancel {
  background: var(--surface);
  color: var(--muted);
}
</style>
